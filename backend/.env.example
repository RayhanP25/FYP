# Copy to .env and adjust if your webcams are not at indices 0 and 1.
# With a laptop built-in cam + 2 USB webcams, use 1 and 2 (not 0).
# Run: curl http://localhost:8000/api/camera/list  (after server starts) to see detected indices.
CAMERA_LEFT_INDEX=1
CAMERA_RIGHT_INDEX=2
CAMERA_OPEN_TIMEOUT_SEC=10
